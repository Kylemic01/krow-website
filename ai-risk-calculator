<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Krow: Free AI Risk & Opportunity Calculator for Accounting Firms</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --navy:#0D2B55;--cobalt:#1A4A8A;--cobalt2:#2563B0;
  --sky:#E8F4FD;--sky2:#BFDBF7;--sky3:#93C5FD;--skyAccent:#3B9FE8;
  --dark:#071828;--text:#0D1F35;--muted:#4A6A8A;
  --white:#FFFFFF;--border:#D1E4F5;--bg:#F0F7FF;
  --red:#DC2626;--redBg:#FEF2F2;--redBorder:#FECACA;
  --amber:#D97706;--amberBg:#FFFBEB;--amberBorder:#FDE68A;
  --green:#1F9D6B;--greenBg:#F0FDF4;--greenBorder:#BBF7D0;
  font-family:'Inter',system-ui,sans-serif;
}
html{scroll-behavior:smooth}
body{background:var(--white);color:var(--text)}

/* NAV */
nav{display:flex;align-items:center;justify-content:space-between;padding:1rem 5%;background:var(--navy);position:sticky;top:0;z-index:100;border-bottom:1px solid rgba(255,255,255,.08)}
.logo{font-size:1.15rem;font-weight:900;color:var(--white);letter-spacing:0.06em;text-decoration:none;text-transform:uppercase;line-height:1.1}
.logo span{color:var(--sky3)}
.logo-sub{font-size:.6rem;font-weight:500;color:rgba(255,255,255,.4);letter-spacing:.12em;text-transform:uppercase;display:block}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{text-decoration:none;color:rgba(255,255,255,.6);font-size:.88rem;transition:color .2s}
.nav-links a:hover{color:var(--white)}
.nav-cta{background:var(--skyAccent);color:white;padding:.5rem 1.3rem;border-radius:6px;text-decoration:none;font-size:.88rem;font-weight:700;transition:background .2s;white-space:nowrap}
.nav-cta:hover{background:var(--cobalt2)}
@media(max-width:640px){.nav-links{display:none}}

/* PAGES */
.page{display:none}.page.active{display:block}

/* HERO */
.hero1{background:linear-gradient(160deg,var(--navy) 0%,var(--cobalt) 55%,#1B5FA0 100%);padding:5rem 5% 0;text-align:center;position:relative;overflow:hidden}
.hero1::before{content:'';position:absolute;top:-40px;right:-60px;width:500px;height:500px;background:radial-gradient(circle,rgba(59,159,232,0.12) 0%,transparent 65%);pointer-events:none}
.hero1::after{content:'';position:absolute;bottom:0;left:0;right:0;height:80px;background:var(--white);clip-path:ellipse(55% 100% at 50% 100%)}
.eyebrow{display:inline-block;background:rgba(147,197,253,0.15);color:var(--sky3);font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.35rem 1rem;border-radius:20px;margin-bottom:1.2rem;border:1px solid rgba(147,197,253,.25)}
.h1{font-size:clamp(2.2rem,5.5vw,3.6rem);font-weight:900;line-height:1.08;letter-spacing:-0.035em;color:var(--white);max-width:820px;margin:0 auto 1rem}
.h1 em{color:var(--sky3);font-style:normal}
.h1-sub{font-size:1.08rem;color:rgba(255,255,255,.7);max-width:580px;margin:0 auto 2.2rem;line-height:1.75}
.hero-cta-btn{display:inline-block;background:var(--skyAccent);color:white;padding:1rem 2.6rem;border-radius:8px;font-size:1.05rem;font-weight:800;text-decoration:none;border:none;cursor:pointer;font-family:inherit;transition:all .2s;box-shadow:0 4px 20px rgba(59,159,232,.35);margin-bottom:2.8rem}
.hero-cta-btn:hover{background:#2b8fd8;transform:translateY(-1px)}
.trust-pills{display:flex;gap:.6rem;justify-content:center;flex-wrap:wrap;margin-bottom:3rem}
.tpill{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.15);border-radius:20px;padding:.3rem .85rem;font-size:.75rem;font-weight:600;color:rgba(255,255,255,.75)}

/* FORM CARD */
.form-card-wrap{max-width:500px;margin:0 auto;position:relative;z-index:2;padding-bottom:2rem}
.form-card{background:var(--white);border:1px solid var(--border);border-radius:16px;padding:2rem 2rem 1.6rem;box-shadow:0 8px 40px rgba(13,43,85,.18)}
.form-card-header{text-align:center;margin-bottom:1.5rem;padding-bottom:1.2rem;border-bottom:1px solid var(--border)}
.form-card-title{font-size:1.05rem;font-weight:800;color:var(--navy);margin-bottom:.25rem}
.form-card-sub{font-size:.8rem;color:var(--muted);line-height:1.5}
.progress-bar{height:3px;background:var(--sky2);border-radius:3px;margin-bottom:1.4rem}
.progress-fill{height:100%;background:var(--cobalt2);border-radius:3px;transition:width .4s ease}
.form-step{display:none;animation:fadein .25s ease}.form-step.active{display:block}
@keyframes fadein{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
.step-counter{font-size:.7rem;font-weight:700;color:var(--muted);margin-bottom:.35rem;letter-spacing:.06em;text-transform:uppercase}
.step-title{font-size:.95rem;font-weight:700;color:var(--navy);margin-bottom:.2rem}
.step-sub{font-size:.8rem;color:var(--muted);margin-bottom:1.1rem;line-height:1.5}
.field{width:100%;padding:.7rem .9rem;border:1.5px solid var(--border);border-radius:7px;font-size:.9rem;margin-bottom:.7rem;color:var(--text);background:var(--white);font-family:inherit;transition:border-color .2s}
.field.invalid{border-color:#C0392B}
.field.invalid:focus{border-color:#C0392B;box-shadow:0 0 0 3px rgba(192,57,43,.12)}
.field-error{display:none;color:#C0392B;font-size:.78rem;margin:-.45rem 0 .75rem 2px;font-weight:600}
.field-error.show{display:block}
.field:focus{outline:none;border-color:var(--cobalt2);box-shadow:0 0 0 3px rgba(37,99,176,.1)}
.goal-grid{display:grid;grid-template-columns:1fr;gap:.55rem;margin-bottom:.9rem}
.goal-card{border:2px solid var(--border);border-radius:8px;padding:.8rem .95rem;cursor:pointer;transition:all .18s;text-align:left;background:var(--white);font-family:inherit;width:100%}
.goal-card:hover{border-color:var(--cobalt2);background:var(--sky)}
.goal-card.selected{border-color:var(--navy);background:var(--sky);box-shadow:0 0 0 3px rgba(13,43,85,.07)}
.goal-card-title{font-size:.88rem;font-weight:700;color:var(--navy);display:flex;align-items:center;gap:.5rem}
.goal-card-sub{font-size:.76rem;color:var(--muted);margin-top:.15rem;padding-left:1.6rem;line-height:1.45}
.btn{width:100%;background:var(--navy);color:white;padding:.82rem;border:none;border-radius:7px;font-size:.95rem;font-weight:800;cursor:pointer;transition:all .2s;font-family:inherit}
.btn:hover{background:var(--cobalt2)}
.btn:disabled{background:var(--sky2);color:var(--muted);cursor:not-allowed}
.btn-back{background:transparent;border:1.5px solid var(--border);color:var(--muted);width:100%;padding:.65rem;border-radius:7px;font-size:.85rem;font-weight:600;cursor:pointer;margin-top:.5rem;font-family:inherit;transition:all .2s}
.btn-back:hover{border-color:var(--cobalt2);color:var(--cobalt2)}
.micro{font-size:.73rem;color:var(--muted);margin-top:.65rem;text-align:center;line-height:1.5}

/* TRUST BAR */
.trust-bar{background:var(--sky);border-bottom:1px solid var(--border);padding:2.4rem 5% 1.8rem;text-align:center}
.trust-bar p{font-size:.72rem;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;font-weight:700;margin-bottom:.8rem}
.logos-row{display:flex;gap:1rem;justify-content:center;align-items:center;flex-wrap:wrap}
.logo-pill{background:var(--white);border:1px solid var(--border);border-radius:6px;padding:.32rem .85rem;font-size:.73rem;font-weight:700;color:var(--navy);letter-spacing:.04em}

/* STATS BAR */
.stats-bar{background:var(--navy);padding:3rem 5%}
.stats-inner{max-width:900px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:0}
.stat-item{text-align:center;padding:1rem;border-right:1px solid rgba(255,255,255,.08)}
.stat-item:last-child{border-right:none}
.stat-n{font-size:2.6rem;font-weight:900;color:var(--sky3);letter-spacing:-0.04em;line-height:1;margin-bottom:.35rem}
.stat-label{font-size:.78rem;font-weight:700;color:rgba(255,255,255,.5);letter-spacing:.04em;text-transform:uppercase;margin-bottom:.25rem}
.stat-desc{font-size:.75rem;color:rgba(255,255,255,.3);line-height:1.5}
@media(max-width:600px){.stats-inner{grid-template-columns:1fr 1fr}.stat-item{border-right:none;border-bottom:1px solid rgba(255,255,255,.08)}.stat-item:nth-child(odd){border-right:1px solid rgba(255,255,255,.08)}}

/* GENERIC SECTION */
.section{padding:5rem 5%}
.section-alt{background:var(--bg)}
.section-dark{background:var(--dark)}
.sec-head{text-align:center;margin-bottom:3rem}
.sec-ey{font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--skyAccent);margin-bottom:.55rem}
.sec-ey-light{color:rgba(147,197,253,.7)}
.sec-h2{font-size:clamp(1.6rem,4vw,2.4rem);font-weight:900;letter-spacing:-0.03em;color:var(--navy);max-width:660px;margin:0 auto .8rem;line-height:1.15}
.sec-h2-light{color:white}
.sec-sub{color:var(--muted);font-size:.95rem;max-width:520px;margin:0 auto;line-height:1.75}
.sec-sub-light{color:rgba(255,255,255,.5)}

/* TRANSFORMATION (before/after) */
.transform-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;max-width:860px;margin:0 auto 2.5rem}
@media(max-width:600px){.transform-grid{grid-template-columns:1fr}}
.transform-col{border-radius:14px;padding:2rem}
.transform-col.before{background:#FFF1F1;border:1.5px solid #FECACA}
.transform-col.after{background:#F0FDF4;border:1.5px solid #BBF7D0}
.transform-label{font-size:.7rem;font-weight:800;letter-spacing:.1em;text-transform:uppercase;margin-bottom:1.2rem;display:flex;align-items:center;gap:.4rem}
.transform-col.before .transform-label{color:#DC2626}
.transform-col.after .transform-label{color:#16A34A}
.transform-dot{width:8px;height:8px;border-radius:50%}
.transform-col.before .transform-dot{background:#DC2626}
.transform-col.after .transform-dot{background:#16A34A}
.transform-item{display:flex;align-items:flex-start;gap:.7rem;margin-bottom:.9rem;font-size:.87rem;line-height:1.6}
.transform-item:last-child{margin-bottom:0}
.transform-col.before .transform-item{color:#7F1D1D}
.transform-col.after .transform-item{color:#14532D}
.ti-icon{flex-shrink:0;margin-top:2px;font-size:.85rem}

/* CASE STUDIES CAROUSEL */
.cases-section{background:var(--dark);padding:5rem 5%}
.cases-scroll-wrap{position:relative;margin-top:2rem}
.cases-scroll{display:flex;gap:1.5rem;overflow-x:auto;scroll-snap-type:x mandatory;-webkit-overflow-scrolling:touch;padding-bottom:1rem;scrollbar-width:none}
.cases-scroll::-webkit-scrollbar{display:none}
.case-card{
  min-width:340px;max-width:340px;border-radius:14px;padding:0;
  background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);
  scroll-snap-align:start;overflow:hidden;flex-shrink:0;
  transition:border-color .2s,transform .2s;cursor:default;
}
.case-card:hover{border-color:rgba(59,159,232,.4);transform:translateY(-3px)}
.case-card-top{padding:1.8rem 1.8rem 1.4rem}
.case-tag{font-size:.68rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--sky3);margin-bottom:.8rem;display:flex;align-items:center;gap:.4rem}
.case-tag-dot{width:6px;height:6px;border-radius:50%;background:var(--sky3);flex-shrink:0}
.case-h{font-size:1.1rem;font-weight:800;color:white;line-height:1.3;margin-bottom:.7rem;letter-spacing:-0.02em}
.case-body{font-size:.84rem;color:rgba(255,255,255,.5);line-height:1.7;margin-bottom:1.2rem}
.case-results{display:flex;gap:1rem;flex-wrap:wrap}
.case-result{background:rgba(59,159,232,.12);border:1px solid rgba(59,159,232,.2);border-radius:8px;padding:.5rem .8rem;text-align:center}
.case-result-n{font-size:1.2rem;font-weight:900;color:var(--sky3);letter-spacing:-0.02em;line-height:1}
.case-result-l{font-size:.65rem;color:rgba(255,255,255,.4);margin-top:.2rem;line-height:1.3}
.case-card-bottom{background:rgba(255,255,255,.03);border-top:1px solid rgba(255,255,255,.07);padding:1.1rem 1.8rem;display:flex;align-items:center;justify-content:space-between}
.case-industry{font-size:.75rem;font-weight:700;color:rgba(255,255,255,.35);letter-spacing:.05em;text-transform:uppercase}
.case-arrow{font-size:.9rem;color:var(--sky3);opacity:.6}
.cases-nav{display:flex;gap:.7rem;margin-top:1.5rem;justify-content:flex-end}
.cases-btn{width:40px;height:40px;border-radius:50%;border:1px solid rgba(255,255,255,.15);background:rgba(255,255,255,.06);color:white;cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;transition:all .2s}
.cases-btn:hover{background:var(--skyAccent);border-color:var(--skyAccent)}

/* HOW IT WORKS */
.how-steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.2rem;max-width:900px;margin:0 auto}
.step{padding:1.6rem;background:var(--white);border:1.5px solid var(--border);border-radius:14px;position:relative}
.step-num{width:36px;height:36px;border-radius:9px;background:var(--sky);display:flex;align-items:center;justify-content:center;font-size:.82rem;font-weight:900;color:var(--navy);margin-bottom:.9rem}
.step-t{font-size:.95rem;font-weight:800;color:var(--navy);margin-bottom:.4rem}
.step-b{font-size:.82rem;color:var(--muted);line-height:1.65}

/* WHO ITS FOR */
.symptoms{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;max-width:900px;margin:0 auto 2.5rem}
.symptom{background:var(--white);border:1.5px solid var(--border);border-radius:12px;padding:1.4rem;display:flex;gap:.9rem;align-items:flex-start}
.symptom-icon{font-size:1.3rem;flex-shrink:0;margin-top:1px}
.symptom-t{font-size:.88rem;font-weight:700;color:var(--navy);margin-bottom:.3rem}
.symptom-b{font-size:.8rem;color:var(--muted);line-height:1.6}

/* TESTIMONIALS */
.tgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.2rem;max-width:920px;margin:0 auto}
.tcard{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:14px;padding:1.6rem;transition:border-color .2s}
.tcard:hover{border-color:rgba(59,159,232,.3)}
.stars{color:#F59E0B;font-size:.88rem;margin-bottom:.8rem}
.ttext{font-size:.87rem;color:rgba(255,255,255,.72);line-height:1.72;margin-bottom:1.2rem}
.tauthor{display:flex;align-items:center;gap:.75rem}
.avatar{width:38px;height:38px;border-radius:50%;background:rgba(59,159,232,.2);display:flex;align-items:center;justify-content:center;font-size:.73rem;font-weight:800;color:var(--sky3);flex-shrink:0}
.aname{font-size:.83rem;font-weight:700;color:white}
.arole{font-size:.72rem;color:rgba(255,255,255,.35);margin-top:1px}
.result-badge{display:inline-block;background:rgba(52,211,153,.12);border:1px solid rgba(52,211,153,.25);border-radius:6px;padding:.2rem .55rem;font-size:.68rem;font-weight:700;color:#34D399;margin-top:.4rem}

/* CTA SECTION */
.cta-section{background:linear-gradient(135deg,var(--navy) 0%,var(--cobalt) 100%);padding:5.5rem 5%;text-align:center}
.cta-section h2{font-size:clamp(1.8rem,4.5vw,2.8rem);font-weight:900;letter-spacing:-0.03em;color:white;margin-bottom:.8rem;line-height:1.12}
.cta-section h2 em{color:var(--sky3);font-style:normal}
.cta-section p{font-size:1rem;color:rgba(255,255,255,.65);max-width:480px;margin:0 auto 2rem;line-height:1.75}
.btn-cta-big{display:inline-block;background:var(--skyAccent);color:white;padding:1.1rem 3rem;border-radius:8px;font-size:1.05rem;font-weight:800;text-decoration:none;border:none;cursor:pointer;font-family:inherit;transition:all .2s;box-shadow:0 4px 24px rgba(59,159,232,.35)}
.btn-cta-big:hover{background:#2b8fd8;transform:translateY(-1px)}
.cta-micro{font-size:.78rem;color:rgba(255,255,255,.3);margin-top:1rem}

/* INLINE CTA STRIP */
.cta-strip{background:var(--sky);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:2rem 5%;display:flex;align-items:center;justify-content:space-between;gap:1.5rem;flex-wrap:wrap}
.cta-strip-text h4{font-size:1rem;font-weight:800;color:var(--navy);margin-bottom:.2rem}
.cta-strip-text p{font-size:.85rem;color:var(--muted)}
.btn-strip{background:var(--navy);color:white;padding:.7rem 1.6rem;border-radius:7px;font-size:.9rem;font-weight:800;text-decoration:none;border:none;cursor:pointer;font-family:inherit;transition:background .2s;white-space:nowrap}
.btn-strip:hover{background:var(--cobalt2)}

/* PAGE 2 — RESULTS */
.dark-section{background:var(--dark);color:white;padding:4rem 5%}
.dark-section .sec-h2{color:white}
.dark-section .sec-ey{color:var(--skyAccent)}
.dark-section .sec-sub{color:rgba(255,255,255,.5)}
.calendly-wrap{max-width:720px;margin:0 auto;border-radius:14px;overflow:hidden}

footer{background:#04101E;color:rgba(255,255,255,.22);text-align:center;padding:2rem 5%;font-size:.76rem;line-height:1.7}
.footer-brand{font-weight:800;color:rgba(255,255,255,.5);letter-spacing:.1em;font-size:.8rem;margin-bottom:.3rem}

/* QUIZ — question types */
.yn-row{display:flex;gap:.6rem;margin-bottom:.9rem}
.yn-btn{flex:1;border:2px solid var(--border);border-radius:8px;padding:.75rem;text-align:center;font-weight:700;font-size:.86rem;color:var(--navy);background:white;cursor:pointer;font-family:inherit;transition:all .18s}
.yn-btn:hover{border-color:var(--cobalt2);background:var(--sky)}
.yn-btn.selected{border-color:var(--navy);background:var(--sky);box-shadow:0 0 0 3px rgba(13,43,85,.07)}
.slider-wrap{margin-bottom:1.1rem}
.slider-val{text-align:center;font-size:2.2rem;font-weight:900;color:var(--navy);margin-bottom:.15rem}
.slider-val .slider-val-num{font-size:3.2rem}
.slider-val .slider-val-unit{font-size:1rem;font-weight:700;color:var(--muted);margin-left:.3rem}
#stepQ5 .step-title{margin-bottom:.7rem}
#stepQ5 .step-sub{margin-bottom:2rem}
.slider-wrap input[type=range]{width:100%;accent-color:var(--cobalt2)}
.slider-labels{display:flex;justify-content:space-between;font-size:.7rem;color:var(--muted);margin-top:.3rem}
.slider-note{text-align:center;font-size:.76rem;color:var(--muted);margin-top:.6rem;margin-bottom:.3rem;background:var(--sky);border-radius:6px;padding:.5rem .7rem;line-height:1.5}

/* RESULTS PAGE */
.results-card{background:#FAFCFE;border:1px solid rgba(13,43,85,.08);border-top:5px solid var(--cobalt2);border-radius:20px;padding:2.8rem 2.2rem;max-width:760px;margin:0 auto;box-shadow:0 25px 60px rgba(0,0,0,.3);text-align:center}
.results-badge{display:inline-flex;align-items:center;gap:.5rem;background:rgba(37,99,176,.1);border:1px solid rgba(37,99,176,.25);border-radius:20px;padding:.4rem 1.1rem;font-size:.76rem;font-weight:800;letter-spacing:.04em;text-transform:uppercase;color:var(--cobalt2);margin-bottom:1.2rem}
.results-h2{font-size:1.6rem;font-weight:900;color:var(--navy);margin-bottom:1.4rem;letter-spacing:-.01em;line-height:1.25}

.risk-pill{display:inline-flex;align-items:center;gap:.6rem;border-radius:30px;padding:.6rem 1.4rem;font-size:.85rem;font-weight:800;letter-spacing:.03em;margin-bottom:2rem;border:1.5px solid}
.risk-pill.low{background:var(--greenBg);border-color:var(--greenBorder);color:var(--green)}
.risk-pill.moderate{background:var(--amberBg);border-color:var(--amberBorder);color:var(--amber)}
.risk-pill.high{background:var(--redBg);border-color:var(--redBorder);color:var(--red)}
.risk-pill-dot{width:9px;height:9px;border-radius:50%;background:currentColor}
.risk-pill-score{font-weight:600;opacity:.75;font-size:.8rem}

.big-red-wrap{background:var(--redBg);border:1.5px solid var(--redBorder);border-radius:16px;padding:2rem 1.6rem;margin-bottom:1.6rem}
.big-red-eyebrow{font-size:.72rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--red);margin-bottom:.6rem}
.big-red-number{font-size:clamp(2.2rem,7vw,3.4rem);font-weight:900;color:var(--red);letter-spacing:-.03em;line-height:1;margin-bottom:.6rem}
.big-red-caption{font-size:.85rem;color:#7F1D1D;line-height:1.6;max-width:460px;margin:0 auto}
.big-red-assumption{font-size:.74rem;color:#991B1B;opacity:.75;margin-top:.6rem}

.bridge-line{font-size:.98rem;font-weight:700;color:var(--navy);line-height:1.55;max-width:560px;margin:0 auto 2rem;padding:0 .5rem}

