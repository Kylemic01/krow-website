{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "landscaping-valuation.html", "use": "@vercel/static" },
    { "src": "hvac-valuation.html", "use": "@vercel/static" },
    { "src": "vsl.html", "use": "@vercel/static" },
    { "src": "accounting.html", "use": "@vercel/static" },
    { "src": "ai-risk-calculator.html", "use": "@vercel/static" },
    { "src": "chaser.html", "use": "@vercel/static" },
    { "src": "memo.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/landscaping-valuation", "dest": "/landscaping-valuation.html" },
    { "src": "/hvac-valuation", "dest": "/hvac-valuation.html" },
    { "src": "/vsl", "dest": "/vsl.html" },
    { "src": "/accounting", "dest": "/accounting.html" },
    { "src": "/ai-risk-calculator", "dest": "/ai-risk-calculator.html" },
    { "src": "/chaser", "dest": "/chaser.html" },
    { "src": "/memo", "dest": "/memo.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
