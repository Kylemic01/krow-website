<script>
let answers={};

const stepProgress={stepQ1:8,stepQ2:20,stepQ3a:32,stepQ3b:42,stepQ4:54,stepQ5:66,stepQ6:78,stepQ7:88,stepContact:99};

function showStep(id){
  document.querySelectorAll('.form-step').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.getElementById('progress').style.width=(stepProgress[id]||50)+'%';
  document.querySelector('.form-card').scrollIntoView({behavior:'smooth',block:'nearest'});
}

/* ---------- Q1: headcount slider ---------- */
function updateHeadcount(v){
  answers.headcount=parseInt(v);
  document.getElementById('headcountVal').textContent=v>=25?'25+':v;
}
updateHeadcount(5); // initialize default

/* ---------- Q2: AI maturity ---------- */
function selectAiMaturity(btn,score){
  document.querySelectorAll('#stepQ2 .goal-card').forEach(c=>c.classList.remove('selected'));
  btn.classList.add('selected');
  answers.aiMaturity=score;
  document.getElementById('q2-next').disabled=false;
}

/* ---------- Q3a: hours slider ---------- */
function updateHours(v){
  answers.hoursPerPerson=parseInt(v);
  document.getElementById('hoursVal').textContent=v>=40?'40+':v;
}
updateHours(14); // initialize default

/* ---------- Q3b: time sink (routes tool recommendation) ---------- */
function selectTimeSink(btn,val){
  document.querySelectorAll('#stepQ3b .goal-card').forEach(c=>c.classList.remove('selected'));
  btn.classList.add('selected');
  answers.timeSink=val;
  document.getElementById('q3b-next').disabled=false;
}

/* ---------- Q4: written policy ---------- */
function selectPolicy(btn,val){
  document.querySelectorAll('#stepQ4 .goal-card').forEach(c=>c.classList.remove('selected'));
  btn.classList.add('selected');
  answers.writtenPolicy=val;
  document.getElementById('q4-next').disabled=false;
}

/* ---------- Q5: FTC awareness ---------- */
function selectFtc(btn,val){
  document.querySelectorAll('#stepQ5 .goal-card').forEach(c=>c.classList.remove('selected'));
  btn.classList.add('selected');
  answers.ftcAwareness=val;
  document.getElementById('q5-next').disabled=false;
}

/* ---------- Q6: shadow AI awareness ---------- */
function selectShadow(btn,val){
  document.querySelectorAll('#stepQ6 .goal-card').forEach(c=>c.classList.remove('selected'));
  btn.classList.add('selected');
  answers.shadowAwareness=val;
  document.getElementById('q6-next').disabled=false;
}

/* ---------- Q7: biggest concern ---------- */
function selectConcern(btn,val){
  document.querySelectorAll('#stepQ7 .goal-card').forEach(c=>c.classList.remove('selected'));
  btn.classList.add('selected');
  answers.concern=val;
  document.getElementById('q7-next').disabled=false;
}

/* ---------- contact gate validation ---------- */
const personalEmailDomains=new Set(['gmail.com','googlemail.com','yahoo.com','yahoo.co.uk','yahoo.co.in','hotmail.com','hotmail.co.uk','outlook.com','live.com','msn.com','aol.com','icloud.com','me.com','mac.com','protonmail.com','proton.me','mail.com','gmx.com','yandex.com','zoho.com','rocketmail.com','ymail.com','comcast.net','verizon.net','att.net','sbcglobal.net','bellsouth.net','cox.net','charter.net','optusnet.com.au','bigpond.com']);

function isValidEmailFormat(v){return /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/.test(v);}
function isBusinessEmail(v){
  if(!isValidEmailFormat(v))return false;
  const domain=v.split('@')[1].toLowerCase().trim();
  return !personalEmailDomains.has(domain);
}
function isValidPhone(v){
  const digits=v.replace(/\D/g,'');
  return digits.length===10||(digits.length===11&&digits[0]==='1');
}
function isFullName(v){
  const parts=v.trim().split(/\s+/).filter(Boolean);
  return parts.length>=2&&parts.every(p=>p.length>=1);
}
function toggleFieldError(field,show){
  document.getElementById(field+'-error').classList.toggle('show',show);
  document.getElementById(field).classList.toggle('invalid',show);
}
function checkContact(){
  const fullname=document.getElementById('fullname').value;
  const bizname=document.getElementById('bizname').value.trim();
  const email=document.getElementById('email').value.trim();
  const phone=document.getElementById('phone').value.trim();

  const nameOk=isFullName(fullname);
  const emailOk=isBusinessEmail(email);
  const phoneOk=isValidPhone(phone);

  toggleFieldError('fullname',fullname.trim()!==''&&!nameOk);
  toggleFieldError('email',email!==''&&!emailOk);
  toggleFieldError('phone',phone!==''&&!phoneOk);

  document.getElementById('contact-submit').disabled=!(nameOk&&!!bizname&&emailOk&&phoneOk);
}

function scrollCases(dir){
  const el=document.getElementById('casesScroll');
  el.scrollBy({left:dir*360,behavior:'smooth'});
}

/* ============================================================
   RISK & OPPORTUNITY CALCULATION ENGINE — fully deterministic.
   ============================================================ */
const BILLABLE_RATE=300;
const WEEKS_PER_YEAR=50;

function money(n){return '$'+Math.round(n).toLocaleString();}

function computeOpportunity(a){
  return (a.headcount||0)*(a.hoursPerPerson||0)*BILLABLE_RATE*WEEKS_PER_YEAR;
}

function computeRiskScore(a){
  let score=100;
  if(a.aiMaturity===0||a.aiMaturity===1)score-=20;          // unmanaged/no use
  if(a.writtenPolicy==='none'||a.writtenPolicy==='notsure')score-=25;
  else if(a.writtenPolicy==='informal')score-=10;
  if(a.ftcAwareness==='no')score-=20;
  return Math.max(0,score);
}

function riskLabel(score){
  if(score>=80)return {label:'Low Risk',cls:'low',emoji:'🟢'};
  if(score>=55)return {label:'Moderate Risk',cls:'moderate',emoji:'🟡'};
  return {label:'High Risk',cls:'high',emoji:'🔴'};
}

function computeObservations(a){
  let pool=[];
  const push=(id,text,priority,polarity)=>pool.push({id,text,priority,polarity:polarity||'fix'});

  if(a.ftcAwareness==='no'){
    push('O-FTC','Most firms don\'t realize the FTC Safeguards Rule applies to them until it\'s raised in a review — worth confirming your status before it comes up that way.',10);
  }
  if(a.writtenPolicy==='none'||a.writtenPolicy==='notsure'){
    push('O-POLICY','An informal or missing AI policy leaves you exposed even when actual usage is well-intentioned — this is usually the fastest of the two numbers above to fix.',9);
  }
  if(a.shadowAwareness==='noidea'){
    push('O-SHADOW','If you\'re not sure what your team is using, assume something is — most unmanaged AI use starts with good intentions and zero visibility. Worth finding out before it becomes a data question instead of a productivity one.',9);
  }
  if(a.aiMaturity===3&&a.writtenPolicy!=='documented'){
    push('O-GAP','You\'ve already invested in real AI tools and workflows — the gap isn\'t adoption, it\'s the paperwork behind it.',7);
  }
  if((a.aiMaturity===0||a.aiMaturity===1)&&a.hoursPerPerson>=15){
    push('O-COMBO','Casual, unmanaged AI use paired with this many manual hours a week is usually the exact combination we see right before a firm both over-exposes itself and under-uses what it\'s already paying for.',8);
  }
  if(a.concern==='privacy'&&a.writtenPolicy==='documented'){
    push('O-STRONG','Data privacy is your top concern, and you\'ve already got a documented policy in place — that puts you ahead of most firms your size on this specific point.',6,'positive');
  }
  if(a.writtenPolicy==='documented'&&a.ftcAwareness==='compliant'){
    push('O-STRONG2','A documented policy and confirmed FTC compliance puts your firm\'s risk management ahead of most in this size range — the opportunity side is where your attention is better spent.',6,'positive');
  }
  push('O-FALLBACK','Every firm carries some version of both numbers above — the size of yours is what the free call is for.',1);

  pool.sort((x,y)=>y.priority-x.priority);
  return pool.slice(0,2);
}

const toolRouting={
  docChasing:{name:'Document Chaser',desc:'Since chasing clients for documents is eating the most time on your team, this is the highest-leverage fix to start with: one upload link, automatic reminders, and a hard deadline per client instead of manual follow-up.'},
  returns:{name:'Advisory Memo Generator',desc:'Since drafting returns and financial statements is eating the most time, this turns your source data into a client-ready first draft — so your time goes into review and sign-off, not building the document from scratch.'},
  dataEntry:{name:'Document Chaser',desc:'Since manual data entry is eating the most time, this usually traces back upstream to how documents arrive in the first place. One upload link, automatic reminders, and a hard deadline per client cuts the mess at the source.'},
  emails:{name:'Advisory Memo Generator',desc:'Since client emails and updates are eating the most time, this turns your notes and numbers into a client-ready first draft — so your time goes into review and the relationship, not the blank page.'},
  mix:{name:'Document Chaser',desc:'Since it\'s a mix of everything, we\'d usually start with document collection first — it tends to have the fastest payoff and the lowest lift to set up. The Advisory Memo Generator is typically the second fix once that\'s live.'}
};

function buildResults(){
  const opportunity=computeOpportunity(answers);
  const riskScore=computeRiskScore(answers);
  const risk=riskLabel(riskScore);
  const firmName=answers.bizname||'Your firm';

  document.getElementById('p2-heading').textContent=firmName+"'s AI Risk & Opportunity Score";

  document.getElementById('p2-risk-pill').innerHTML=`
    <div class="risk-pill ${risk.cls}">
      <span class="risk-pill-dot"></span>
      ${risk.emoji} ${risk.label}
      <span class="risk-pill-score">— ${riskScore}/100</span>
    </div>`;

  document.getElementById('p2-big-red').innerHTML=`
    <div class="big-red-wrap">
      <div class="big-red-eyebrow">Estimated Annual Opportunity</div>
      <div class="big-red-number">Up to ${money(opportunity)}/yr</div>
      <div class="big-red-caption">Based on your answers, ${firmName} could be leaving this much a year on the table in recoverable capacity.</div>
      <div class="big-red-assumption">Assumes a $${BILLABLE_RATE}/hr billable rate across your team, applied across ${answers.headcount>=25?'25+':answers.headcount} people at ${answers.hoursPerPerson>=40?'40+':answers.hoursPerPerson} hrs/week each, 50 weeks a year. An estimate to guide priority, not a guarantee.</div>
    </div>`;

  const chips=[
    (answers.headcount>=25?'25+':answers.headcount)+' team members',
    (answers.hoursPerPerson>=40?'40+':answers.hoursPerPerson)+' hrs/week manual work',
    '$'+BILLABLE_RATE+'/hr rate assumed'
  ];
  document.getElementById('p2-snapshot').innerHTML=chips.map(c=>`<span class="snapshot-chip">${c}</span>`).join('');

  const obs=computeObservations(answers);
  document.getElementById('p2-observations').innerHTML=obs.map(o=>`
    <div class="finding-card ${o.polarity==='positive'?'positive':''}">
      <div class="finding-tag">${o.polarity==='positive'?'Working in your favor':'Worth addressing'}</div>
      <div class="finding-b">${o.text}</div>
    </div>`).join('');

  const tool=toolRouting[answers.timeSink]||toolRouting.mix;
  document.getElementById('p2-tool').innerHTML=`
    <div class="tool-card">
      <div class="tool-eyebrow">Recommended Free Tool</div>
      <div class="tool-h">${tool.name}</div>
      <div class="tool-b">${tool.desc}</div>
    </div>`;
}

// Get your free access key at https://web3forms.com — takes 30 seconds, no account needed.
// Reusing the same key as the main Krow site keeps leads in one inbox.
const WEB3FORMS_ACCESS_KEY = "3f46aea5-82f3-4c90-b64c-dc6e244bb85f";

function sendLeadNotification(payload){
  if(WEB3FORMS_ACCESS_KEY === "YOUR_WEB3FORMS_ACCESS_KEY"){
    console.warn("Web3Forms access key not set — lead was captured but NOT emailed.");
    return;
  }
  const allFields = {
    access_key: WEB3FORMS_ACCESS_KEY,
    subject: `New AI Risk & Opportunity Calculator Lead — ${payload.name} (${payload.bizname})`,
    from_name: 'Krow AI Risk & Opportunity Calculator',
    ...payload
  };

  const iframeName = 'w3f_iframe_' + Date.now();
  const iframe = document.createElement('iframe');
  iframe.name = iframeName;
  iframe.style.display = 'none';
  document.body.appendChild(iframe);

  const form = document.createElement('form');
  form.action = 'https://api.web3forms.com/submit';
  form.method = 'POST';
  form.target = iframeName;
  form.style.display = 'none';

  for(const [key, value] of Object.entries(allFields)){
    const input = document.createElement('input');
    input.type = 'hidden';
    input.name = key;
    input.value = value;
    form.appendChild(input);
  }
  document.body.appendChild(form);
  form.submit();

  setTimeout(() => { form.remove(); iframe.remove(); }, 5000);
}

function submitForm(){
  answers.fullname=document.getElementById('fullname').value.trim();
  answers.bizname=document.getElementById('bizname').value.trim();
  answers.email=document.getElementById('email').value.trim();
  answers.phone=document.getElementById('phone').value.trim();

  const opportunity=computeOpportunity(answers);
  const riskScore=computeRiskScore(answers);

  sendLeadNotification({
    name: answers.fullname,
    bizname: answers.bizname,
    email: answers.email,
    phone: answers.phone,
    headcount: answers.headcount,
    aiMaturity: answers.aiMaturity,
    hoursPerPerson: answers.hoursPerPerson,
    timeSink: answers.timeSink,
    writtenPolicy: answers.writtenPolicy,
    ftcAwareness: answers.ftcAwareness,
    shadowAwareness: answers.shadowAwareness,
    concern: answers.concern,
    estimated_annual_opportunity: opportunity,
    risk_score: riskScore
  });

  buildResults();
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('p2').classList.add('active');
  window.scrollTo({top:0,behavior:'smooth'});
}
</script>
